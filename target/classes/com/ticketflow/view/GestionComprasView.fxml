<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="15" styleClass="root" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.ticketflow.controller.GestionComprasController">
    <Label text="Gestión de Compras (Admin)" styleClass="title-label"/>
    
    <HBox spacing="10" alignment="CENTER_LEFT">
        <Button fx:id="btnCancelar" text="Cancelar Compra Seleccionada" onAction="#onCancelarCompra" styleClass="button-primary"/>
        <Button fx:id="btnDeshacer" text="Deshacer Última Acción (Command Pattern)" onAction="#onDeshacerUltimaAccion" styleClass="button-secondary" disable="true"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="lblMensaje" textFill="#4CAF50"/>
    </HBox>
    
    <TableView fx:id="tvCompras" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colId" text="ID Corto" prefWidth="100"/>
            <TableColumn fx:id="colUsuario" text="Usuario" prefWidth="200"/>
            <TableColumn fx:id="colEvento" text="Evento" prefWidth="200"/>
            <TableColumn fx:id="colFecha" text="Fecha" prefWidth="150"/>
            <TableColumn fx:id="colTotal" text="Total" prefWidth="100"/>
            <TableColumn fx:id="colEstado" text="Estado" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
