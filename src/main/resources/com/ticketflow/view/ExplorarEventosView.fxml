<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="15" styleClass="root" xmlns:fx="http://javafx.com/fxml" 
      fx:controller="com.ticketflow.controller.ExplorarEventosController">
    <Label text="Explorar Eventos" styleClass="title-label"/>
    
    <!-- Filtros -->
    <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
        <VBox spacing="5">
            <Label text="Fecha:"/>
            <DatePicker fx:id="dpFecha" prefWidth="120"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Ciudad:"/>
            <ComboBox fx:id="cmbCiudad" prefWidth="120"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Categoría:"/>
            <ComboBox fx:id="cmbCategoria" prefWidth="120"/>
        </VBox>
        <VBox spacing="5">
            <Label text="Precio Máx ($):"/>
            <TextField fx:id="txtPrecioMax" prefWidth="100"/>
        </VBox>
        <VBox alignment="BOTTOM_CENTER" spacing="5">
            <HBox spacing="5">
                <Button text="Filtrar" onAction="#onFiltrar" styleClass="button-primary"/>
                <Button text="Limpiar" onAction="#onLimpiar" styleClass="button-secondary"/>
            </HBox>
        </VBox>
    </HBox>
    
    <Label text="Haz doble clic en un evento para ver detalles y comprar." styleClass="subtitle-label"/>
    
    <!-- Tabla -->
    <TableView fx:id="tvEventos" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colNombre" text="Evento" prefWidth="250"/>
            <TableColumn fx:id="colFecha" text="Fecha y Hora" prefWidth="150"/>
            <TableColumn fx:id="colCiudad" text="Ciudad" prefWidth="150"/>
            <TableColumn fx:id="colCategoria" text="Categoría" prefWidth="120"/>
        </columns>
    </TableView>
</VBox>
